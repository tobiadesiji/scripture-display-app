generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PresentationSessionStatus {
  DRAFT
  LIVE
  ENDED
}

enum DisplayLinkMode {
  DISPLAY
  REMOTE
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  role          String?  @default("user")

  sessions             Session[]
  accounts             Account[]
  presentationSessions PresentationSession[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime
}

model PresentationSession {
  id               String                    @id @default(cuid())
  ownerUserId      String
  title            String?
  status           PresentationSessionStatus @default(DRAFT)
  currentReference String?
  currentVersion   String?
  settingsJson     Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  owner        User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  displayLinks DisplayLink[]

  @@index([ownerUserId, updatedAt])
}

model DisplayLink {
  id                    String          @id @default(cuid())
  presentationSessionId String
  tokenHash             String          @unique
  mode                  DisplayLinkMode @default(DISPLAY)
  expiresAt             DateTime?
  revokedAt             DateTime?
  createdAt             DateTime        @default(now())

  presentationSession PresentationSession @relation(fields: [presentationSessionId], references: [id], onDelete: Cascade)

  @@index([presentationSessionId])
}
